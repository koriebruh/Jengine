# Local dev only - never real credentials. Copy to .env and adjust if needed;
# .env itself is gitignored. Consumed by docker-compose.yaml and (later)
# internal/platform/config. See plans/docs/16-development-workflow.md §16.3
# and plans/task/core/02.

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jengine
POSTGRES_PASSWORD=jengine_dev
POSTGRES_DB=jengine

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PORT=6379

# --- Redpanda (Kafka API) ---
REDPANDA_BROKERS=localhost:9092
REDPANDA_KAFKA_PORT=9092
REDPANDA_SCHEMA_REGISTRY_PORT=8081
REDPANDA_ADMIN_PORT=9644

# --- MinIO (S3-compatible object storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=jengine
MINIO_SECRET_KEY=jengine_dev_secret
MINIO_BUCKET_STATEMENTS=jengine-statements
MINIO_BUCKET_AUDIT=jengine-audit-archive

# --- Temporal ---
TEMPORAL_HOST_PORT=localhost:7233
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8080
